{% extends 'base.html.twig' %}

{% block title %}Products - Our Store{% endblock %}

{% block content %}
    <div class="container my-5">
        <h1 class="mb-4">Our Products</h1>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
            <div class="col">
                <div class="card h-100">
                    <img src="{{ asset(product.mainImage.url) }}" class="card-img-top" alt="{{ product.mainImage.alt }}">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text fw-bold text-success">{{ product.price|number_format(2, '.', ',') }} €</p>
                        <a href="{{ path('app_product', {'id': product.id}) }}" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12">
                <div class="alert alert-info">No products available at the moment.</div>
            </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
